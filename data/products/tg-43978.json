    "title": "\u062f\u0631\u064a\u0633 \u0645\u0637\u0639\u0645 \u062c\u064a\u0646\u0632 \n\n\u064a\u0627 \u0648\u062f\u064a\u0639 \u064a\u0627 \u062f\u0644\u0639 \ud83d\ude0d\ud83d\udd25  \n\u062f\u0647 \u0645\u0634 \u0641\u0633\u062a\u0627\u0646 \u062f\u0647 \"\u0641\u0633\u062a\u0627\u0646 \u0627\u0644\u062e\u0631\u0648\u062c\u0627\u062a \u0627\u0644\u0644\u064a \u062a\u0644\u0628\u0633\u064a\u0647 \u0648\u062a\u0646\u0633\u064a \u0646\u0641\u0633\u0643 \u0641\u064a\u0647\" \ud83d\ude48\n\n\u0647\u062a\u0645\u0648\u062a\u064a \u0641\u064a\u0647 \u0644\u064a\u0647\u061f \u2728  \n\u0627\u0644\u062a\u0635\u0645\u064a\u0645 \u0645\u064a\u0643\u0633 \u062c\u064a\u0646\u0632 \u0645\u0639 \u0623\u0633\u0648\u062f \u064a\u0639\u0646\u064a \u0639\u0645\u0644\u064a \u0648\u0634\u064a\u0643 \u0641\u064a \u0646\u0641\u0633 \u0627\u0644\u0648\u0642\u062a \u0648\u0645\u0634 \u062a\u0642\u0644\u064a\u062f\u064a\ud83d\udda4\ud83d\udc99\n \n\u0627\u0644\u0633\u0648\u0633\u062a\u0629 \u0642\u062f\u0627\u0645 \u0637\u0648\u0644\u062a \u0627\u0644\u0641\u0633\u062a\u0627\u0646 \u0633\u0647\u0644 \u0641\u064a \u0627\u0644\u0644\u0628\u0633 \u0648\u0627\u0644\u0642\u0644\u0639 \u0648\u062a\u0642\u062f\u0631\u064a \u062a\u0641\u062a\u062d\u064a\u0647\u0627 \u0634\u0648\u064a\u0629 \u0639\u0644\u0649 \u062a\u0648\u0628\ud83e\udef6\u2764\ufe0f\n  \n\u0627\u0644\u0643\u0645 \u0628\u0627\u0641 \u0628\u0643\u0634\u0643\u0634\u0629 \u0648\u0641\u064a\u0647 3 \u062e\u0637\u0648\u0637 \u0628\u064a\u0636\u0627 \u062a\u062f\u064a \u0633\u062a\u0627\u064a\u0644 \u0631\u064a\u0627\u0636\u064a \u0631\u0627\u064a\u0642 \u0623\u0648\u064a \ud83d\ude0e\u2728\u2728\n\n\u0627\u0644\u0628\u0633\u0647 \u0627\u0632\u0627\u064a\u061f\ud83d\udc47\n\u0645\u0639 \u0634\u0646\u0637\u0629 \u0632\u0628\u0631\u0627 + \u0646\u0636\u0627\u0631\u0629 + \u0635\u0646\u062f\u0644 \u0632\u064a \u0627\u0644\u0635\u0648\u0631\u0629 = \"\u0646\u0627\u0632\u0644\u0629 \u0623\u0635\u0648\u0631 \u0648\u0623\u0644\u0641\" \ud8